table train
	lineageTag: d3f6ebd3-a806-43f3-b93d-129e33d4a1c9

	measure 'Total Sales' = sum(train[Sales])
		lineageTag: 70dfa3da-3d0e-4fad-90fa-5485997c7396

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'YoY Growth %' =
			
			VAR CurrentYear = SUM('train'[Sales])
			VAR PriorYear = CALCULATE(SUM('train'[Sales]), DATEADD('train'[Order Date], -1, YEAR))
			RETURN DIVIDE(CurrentYear - PriorYear, PriorYear, 0)
		lineageTag: 2d0fc647-1677-4fb4-8598-be6cee6fabf4

		annotation PBI_FormatHint = {"isGeneralNumber":true}

